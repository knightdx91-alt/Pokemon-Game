+// Each starter slot is rolled randomly across every real species when the
+// starter screen opens. The boss/alpha roll in Task_HandleStarterMenuInput
+// still runs on whichever one is chosen, so any random starter can become a
+// boss (special icon + all-31 IVs).
+EWRAM_DATA static u16 sRandomizedStarters[STARTER_MON_COUNT] = {0};
+EWRAM_DATA static bool8 sStartersRandomized = FALSE;
+
+static u16 GetRandomStarterSpecies(void)
+{
+    u16 species;
+    do {
+        species = (Random() % (NUM_SPECIES - 1)) + 1;   // 1 .. NUM_SPECIES-1
+    } while (gBaseStats[species].baseHP == 0);           // skip empty/placeholder slots
+    return species;
+}
+
+static void RandomizeStarters(void)
+{
+    u8 i;
+    for (i = 0; i < STARTER_MON_COUNT; i++)
+        sRandomizedStarters[i] = GetRandomStarterSpecies();
+    // The center starter slot (the default cursor position) is always Ralts.
+    sRandomizedStarters[3] = SPECIES_RALTS;
+    sStartersRandomized = TRUE;
+}
+
 static const struct BgTemplate sBgTemplates[3] =
 {
