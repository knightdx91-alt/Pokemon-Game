+// Roll a random real species (1..NUM_SPECIES-1), skipping empty/placeholder
+// base-stat slots. Re-rolled on every wild encounter so every route/patch of
+// grass/water/fishing spot produces random Pokemon.
+static u16 GetRandomWildSpecies(void)
+{
+    u16 species;
+    do {
+        species = (Random() % (NUM_SPECIES - 1)) + 1;
+    } while (gBaseStats[species].baseHP == 0);
+    return species;
+}
+
 void CreateWildMon(u16 species, u8 level)
 {
     bool32 checkCuteCharm;
 
+    // Every wild encounter is randomized; the route's natural level is kept.
+    species = GetRandomWildSpecies();
+
     ZeroEnemyPartyMons();
     checkCuteCharm = TRUE;
 
